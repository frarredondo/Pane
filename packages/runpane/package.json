{
  "name": "runpane",
  "version": "2.3.14",
  "description": "Thin npm installer and remote setup CLI for Pane",
  "license": "AGPL-3.0",
  "homepage": "https://runpane.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcouple/Pane.git",
    "directory": "packages/runpane"
  },
  "bugs": {
    "url": "https://github.com/dcouple/Pane/issues"
  },
  "bin": {
    "runpane": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/mark-executable.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
