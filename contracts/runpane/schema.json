{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runpane.com/schemas/runpane-contract.schema.json",
  "title": "Runpane public contract manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "description",
    "packageInstallPolicy",
    "compatibility",
    "terminology",
    "defaults",
    "enums",
    "commands",
    "flags",
    "help",
    "docs",
    "testFixtures",
    "jsonSchemas"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "name": { "const": "runpane" },
    "description": { "type": "string", "minLength": 1 },
    "packageInstallPolicy": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "compatibility": {
      "type": "object",
      "required": ["node", "python"],
      "properties": {
        "node": { "type": "string", "minLength": 1 },
        "python": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "terminology": {
      "type": "object",
      "required": ["repo", "pane", "tool", "agent"],
      "properties": {
        "repo": { "type": "string" },
        "pane": { "type": "string" },
        "tool": { "type": "string" },
        "agent": { "type": "string" }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "required": ["target", "paneVersion", "channel", "format", "dryRun", "yes", "verbose"],
      "properties": {
        "target": { "type": "string" },
        "paneVersion": { "type": "string" },
        "channel": { "type": "string" },
        "format": { "type": "string" },
        "dryRun": { "type": "boolean" },
        "yes": { "type": "boolean" },
        "verbose": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "enums": {
      "type": "object",
      "required": ["installTargets", "artifactFormats", "channels"],
      "properties": {
        "installTargets": { "$ref": "#/$defs/stringList" },
        "artifactFormats": { "$ref": "#/$defs/stringList" },
        "channels": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/command" },
      "minItems": 1
    },
    "flags": {
      "type": "object",
      "required": ["wrapper", "remoteValue", "remoteBoolean"],
      "properties": {
        "wrapper": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        },
        "remoteValue": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        },
        "remoteBoolean": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        }
      },
      "additionalProperties": false
    },
    "help": {
      "type": "object",
      "required": ["npm", "pip"],
      "properties": {
        "npm": { "$ref": "#/$defs/helpSurface" },
        "pip": { "$ref": "#/$defs/helpSurface" }
      },
      "additionalProperties": false
    },
    "docs": { "type": "object" },
    "testFixtures": { "type": "object" },
    "jsonSchemas": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "command": {
      "type": "object",
      "required": ["name", "summary", "usage"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "usage": { "$ref": "#/$defs/stringList" },
        "interactiveEntrypoint": { "type": "boolean" },
        "defaultTarget": { "type": "string" },
        "targets": { "$ref": "#/$defs/stringList" },
        "target": { "type": "string" },
        "unknownDaemonFlagsForwarded": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "flag": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "pattern": "^--" },
        "value": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "helpSurface": {
      "type": "object",
      "required": ["default", "install", "setup", "update", "version", "doctor"],
      "properties": {
        "default": { "$ref": "#/$defs/helpLines" },
        "install": { "$ref": "#/$defs/helpLines" },
        "setup": { "$ref": "#/$defs/helpLines" },
        "update": { "$ref": "#/$defs/helpLines" },
        "version": { "$ref": "#/$defs/helpLines" },
        "doctor": { "$ref": "#/$defs/helpLines" }
      },
      "additionalProperties": false
    },
    "helpLines": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
