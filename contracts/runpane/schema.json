{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runpane.com/schemas/runpane-contract.schema.json",
  "title": "Runpane public contract manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "description",
    "packageInstallPolicy",
    "compatibility",
    "terminology",
    "defaults",
    "enums",
    "agentTemplates",
    "agentContext",
    "commands",
    "flags",
    "help",
    "docs",
    "testFixtures",
    "jsonSchemas"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "const": "runpane"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "packageInstallPolicy": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "compatibility": {
      "type": "object",
      "required": [
        "node",
        "python"
      ],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "python": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "terminology": {
      "type": "object",
      "required": [
        "repo",
        "pane",
        "tool",
        "agent"
      ],
      "properties": {
        "repo": {
          "type": "string"
        },
        "pane": {
          "type": "string"
        },
        "tool": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "required": [
        "target",
        "paneVersion",
        "channel",
        "format",
        "dryRun",
        "yes",
        "verbose"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "paneVersion": {
          "type": "string"
        },
        "channel": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "dryRun": {
          "type": "boolean"
        },
        "yes": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "enums": {
      "type": "object",
      "required": [
        "installTargets",
        "artifactFormats",
        "channels",
        "agents"
      ],
      "properties": {
        "installTargets": {
          "$ref": "#/$defs/stringList"
        },
        "artifactFormats": {
          "$ref": "#/$defs/stringList"
        },
        "channels": {
          "$ref": "#/$defs/stringList"
        },
        "agents": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "agentTemplates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/agentTemplate"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command"
      },
      "minItems": 1
    },
    "flags": {
      "type": "object",
      "required": [
        "wrapper",
        "remoteValue",
        "remoteBoolean",
        "localValue",
        "localBoolean"
      ],
      "properties": {
        "wrapper": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flag"
          }
        },
        "remoteValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flag"
          }
        },
        "remoteBoolean": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flag"
          }
        },
        "localValue": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flag"
          }
        },
        "localBoolean": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/flag"
          }
        }
      },
      "additionalProperties": false
    },
    "help": {
      "type": "object",
      "required": [
        "npm",
        "pip"
      ],
      "properties": {
        "npm": {
          "$ref": "#/$defs/helpSurface"
        },
        "pip": {
          "$ref": "#/$defs/helpSurface"
        }
      },
      "additionalProperties": false
    },
    "docs": {
      "type": "object"
    },
    "testFixtures": {
      "type": "object"
    },
    "jsonSchemas": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "agentContext": {
      "$ref": "#/$defs/agentContext"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "command": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "usage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "usage": {
          "$ref": "#/$defs/stringList"
        },
        "interactiveEntrypoint": {
          "type": "boolean"
        },
        "defaultTarget": {
          "type": "string"
        },
        "targets": {
          "$ref": "#/$defs/stringList"
        },
        "target": {
          "type": "string"
        },
        "unknownDaemonFlagsForwarded": {
          "type": "boolean"
        },
        "mutates": {
          "type": "boolean"
        },
        "jsonSchemas": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "agentTemplate": {
      "type": "object",
      "required": [
        "title",
        "command"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "flag": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^--"
        },
        "value": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "helpSurface": {
      "type": "object",
      "required": [
        "default",
        "install",
        "setup",
        "update",
        "version",
        "doctor",
        "agents doctor",
        "repos list",
        "repos add",
        "panes",
        "panes list",
        "panes create",
        "panes archive",
        "panels",
        "panels create",
        "panels list",
        "panels output",
        "panels input",
        "panels screen",
        "panels submit",
        "panels submit-composer",
        "panels wait",
        "agent-context"
      ],
      "properties": {
        "default": {
          "$ref": "#/$defs/helpLines"
        },
        "install": {
          "$ref": "#/$defs/helpLines"
        },
        "setup": {
          "$ref": "#/$defs/helpLines"
        },
        "update": {
          "$ref": "#/$defs/helpLines"
        },
        "version": {
          "$ref": "#/$defs/helpLines"
        },
        "doctor": {
          "$ref": "#/$defs/helpLines"
        },
        "agents doctor": {
          "$ref": "#/$defs/helpLines"
        },
        "repos list": {
          "$ref": "#/$defs/helpLines"
        },
        "repos add": {
          "$ref": "#/$defs/helpLines"
        },
        "panes": {
          "$ref": "#/$defs/helpLines"
        },
        "panes list": {
          "$ref": "#/$defs/helpLines"
        },
        "panes create": {
          "$ref": "#/$defs/helpLines"
        },
        "panes archive": {
          "$ref": "#/$defs/helpLines"
        },
        "panels": {
          "$ref": "#/$defs/helpLines"
        },
        "panels create": {
          "$ref": "#/$defs/helpLines"
        },
        "panels list": {
          "$ref": "#/$defs/helpLines"
        },
        "panels output": {
          "$ref": "#/$defs/helpLines"
        },
        "panels input": {
          "$ref": "#/$defs/helpLines"
        },
        "panels screen": {
          "$ref": "#/$defs/helpLines"
        },
        "panels submit": {
          "$ref": "#/$defs/helpLines"
        },
        "panels submit-composer": {
          "$ref": "#/$defs/helpLines"
        },
        "panels wait": {
          "$ref": "#/$defs/helpLines"
        },
        "agent-context": {
          "$ref": "#/$defs/helpLines"
        }
      },
      "additionalProperties": false
    },
    "helpLines": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "agentContext": {
      "type": "object",
      "required": [
        "brief",
        "commands",
        "managedBlock"
      ],
      "properties": {
        "brief": {
          "$ref": "#/$defs/agentContextBrief"
        },
        "commands": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/agentContextCommand"
          }
        },
        "managedBlock": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "agentContextBrief": {
      "type": "object",
      "required": [
        "title",
        "summary",
        "rules",
        "detailCommand",
        "tools"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "rules": {
          "$ref": "#/$defs/stringList"
        },
        "detailCommand": {
          "type": "string",
          "minLength": 1
        },
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/agentContextTool"
          }
        }
      },
      "additionalProperties": false
    },
    "agentContextTool": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "arguments"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "arguments": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "agentContextCommand": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "details",
        "arguments",
        "examples"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "string",
          "minLength": 1
        },
        "requiresPaneDaemon": {
          "type": "boolean"
        },
        "mutates": {
          "type": "boolean"
        },
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agentContextArgument"
          }
        },
        "examples": {
          "$ref": "#/$defs/stringList"
        },
        "jsonSchemas": {
          "$ref": "#/$defs/stringList"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "agentContextArgument": {
      "type": "object",
      "required": [
        "name",
        "required",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
